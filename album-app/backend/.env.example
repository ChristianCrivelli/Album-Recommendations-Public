# Use a READ-ONLY Supabase key here (anon key + RLS policies that only
# allow SELECT on albums / album_tags / tags / album_contributions / artists).
# Never put your write/service key in the public app's environment.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-read-only-anon-key

# Comma-free single origin your frontend will be deployed at, e.g.
# https://album-recs.vercel.app  (use * only while testing locally)
FRONTEND_ORIGIN=*

# Optional: set this to protect POST /api/refresh with a bearer token
ADMIN_REFRESH_TOKEN=

# How long (seconds) to keep the feature matrix cached before auto-rebuilding
CACHE_TTL_SECONDS=3600
